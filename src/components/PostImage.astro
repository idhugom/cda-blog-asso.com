---
import type { Post } from '../lib/posts';
import { imageFor } from '../lib/images';

interface Props {
  post: Post;
  sizes?: string;
  eager?: boolean;
  class?: string;
  ratio?: string;
}
const { post, sizes = '(max-width: 720px) 100vw, 720px', eager = false, class: cls = '', ratio } = Astro.props;
const img = imageFor(post);
---
{
  img ? (
    <div class={`ph ${cls}`} style={`--bg:${img.bg};${ratio ? `aspect-ratio:${ratio};` : ''}`}>
      <img
        src={img.src}
        srcset={img.srcset}
        sizes={img.srcset ? sizes : undefined}
        width={img.width}
        height={img.height}
        alt={img.alt}
        loading={eager ? 'eager' : 'lazy'}
        fetchpriority={eager ? 'high' : 'auto'}
        decoding={eager ? 'sync' : 'async'}
      />
    </div>
  ) : (
    <div class={`ph ph--empty ${cls}`} style={ratio ? `aspect-ratio:${ratio}` : ''} aria-hidden="true" />
  )
}

<style>
  .ph {
    position: relative;
    overflow: hidden;
    background: var(--bg, var(--paper-2));
    width: 100%;
  }
  .ph img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ph--empty {
    background: linear-gradient(135deg, var(--paper-2), color-mix(in oklab, var(--accent) 8%, var(--paper-2)));
  }
</style>
