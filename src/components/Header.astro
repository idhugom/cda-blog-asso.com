---
import { NAV, SITE } from '../lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="site-header" data-header data-scrolled="false">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label={`${SITE.name} — accueil`}>
      <span class="brand__mark" aria-hidden="true">
        <span class="brand__dot"></span>
      </span>
      <span class="brand__text">
        <span class="brand__name">{SITE.name}</span>
        <span class="brand__sub">Le magazine</span>
      </span>
    </a>

    <nav class="site-nav" id="site-nav" data-open="false" aria-label="Navigation principale">
      <ul class="site-nav__list">
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} class="site-nav__link" data-active={isActive(item.href)}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <button class="icon-btn" data-theme-toggle aria-label="Changer de thème (clair / sombre)">
        <svg class="icon-btn__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg class="icon-btn__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
      <button class="icon-btn menu-btn" data-menu-toggle aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="site-nav">
        <span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 80;
    background: color-mix(in oklab, var(--paper) 82%, transparent);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-2) var(--ease), background var(--dur-2) var(--ease);
  }
  .site-header[data-scrolled='true'] {
    border-bottom-color: var(--line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.6rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .brand__mark {
    position: relative;
    width: 34px;
    height: 34px;
    border: 1.5px solid var(--ink);
    border-radius: 9px;
    display: grid;
    place-items: center;
    transition: transform var(--dur-2) var(--ease), border-color var(--dur-2) var(--ease);
  }
  .brand:hover .brand__mark {
    transform: rotate(-8deg);
    border-color: var(--accent);
  }
  .brand__dot {
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    transition: transform var(--dur-2) var(--ease);
  }
  .brand:hover .brand__dot {
    transform: scale(1.25);
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand__name {
    font-family: var(--font-display);
    font-size: 1.32rem;
    font-weight: 500;
    letter-spacing: -0.02em;
  }
  .brand__sub {
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-top: 3px;
  }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-nav__link {
    display: inline-block;
    padding: 0.5rem 0.85rem;
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--ink-soft);
    border-radius: var(--r-pill);
    transition: color var(--dur-2) var(--ease), background var(--dur-2) var(--ease);
  }
  .site-nav__link:hover {
    color: var(--ink);
    background: color-mix(in oklab, var(--ink) 5%, transparent);
  }
  .site-nav__link[data-active='true'] {
    color: var(--ink);
    background: color-mix(in oklab, var(--ink) 7%, transparent);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .icon-btn {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: var(--ink-soft);
    border: 1px solid transparent;
    transition: color var(--dur-2) var(--ease), background var(--dur-2) var(--ease), border-color var(--dur-2) var(--ease);
  }
  .icon-btn:hover {
    color: var(--ink);
    border-color: var(--line-2);
  }
  .icon-btn__moon { display: none; }
  :root[data-theme='dark'] .icon-btn__sun { display: none; }
  :root[data-theme='dark'] .icon-btn__moon { display: block; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) .icon-btn__sun { display: none; }
    :root:not([data-theme='light']) .icon-btn__moon { display: block; }
  }

  .menu-btn { display: none; flex-direction: column; gap: 5px; }
  .menu-btn span {
    width: 18px;
    height: 1.6px;
    background: var(--ink);
    transition: transform var(--dur-2) var(--ease), opacity var(--dur-1) var(--ease);
  }

  @media (max-width: 820px) {
    .menu-btn { display: flex; }
    .site-nav {
      position: fixed;
      inset: 4.6rem 0 0 0;
      background: var(--paper);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--dur-2) var(--ease), transform var(--dur-2) var(--ease);
      padding: 2rem var(--gutter);
      border-top: 1px solid var(--line);
    }
    .site-nav[data-open='true'] {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
    .site-nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }
    .site-nav__link {
      font-size: var(--step-2);
      font-family: var(--font-display);
      padding: 0.5rem 0;
    }
  }
</style>
