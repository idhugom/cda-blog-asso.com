---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import { getCategoriesWithCounts, loadPosts } from '../../lib/posts';
import { SITE } from '../../lib/site';

const cats = getCategoriesWithCounts();
const posts = loadPosts();
---

<BaseLayout
  title="Rubriques"
  description="Les rubriques du magazine CDA : auto, assurance, maison, mode, voyage, santé, loisirs et plus. Explorez nos guides thématiques."
>
  <section class="container rub-hero">
    <span class="u-label u-label--accent" data-reveal>Explorer par thème</span>
    <h1 class="rub-hero__title" data-reveal>Les rubriques</h1>
    <p class="rub-hero__lead measure" data-reveal style="--reveal-delay:.05s">
      Chaque rubrique rassemble nos décryptages et comparatifs sur un univers. Choisissez le vôtre.
    </p>
  </section>

  <section class="container">
    <div class="rub-grid">
      {cats.map((c, i) => {
        const latest = posts.filter((p) => p.category.slug === c.slug).slice(0, 3);
        return (
          <a href={`/rubriques/${c.slug}/`} class="rub-card" data-reveal style={`--reveal-delay:${i * 0.04}s`}>
            <div class="rub-card__top">
              <span class="rub-card__icon"><CategoryIcon name={c.icon} size={24} /></span>
              <span class="rub-card__count u-num">{c.count} article{c.count > 1 ? 's' : ''}</span>
            </div>
            <h2 class="rub-card__name">{c.name}</h2>
            <p class="rub-card__blurb">{c.blurb}</p>
            <ul class="rub-card__list">
              {latest.map((p) => <li>{p.title}</li>)}
            </ul>
            <span class="rub-card__go">Voir la rubrique <span class="btn__arrow">→</span></span>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .rub-hero { padding-top: clamp(2rem, 5vw, 3.5rem); }
  .rub-hero__title { font-size: var(--step-5); margin-top: 0.5rem; }
  .rub-hero__lead { margin-top: 1rem; color: var(--ink-soft); font-size: var(--step-1); }
  .rub-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 900px) { .rub-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .rub-grid { grid-template-columns: 1fr; } }
  .rub-card {
    display: flex;
    flex-direction: column;
    padding: 1.6rem;
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    background: var(--surface);
    transition: transform var(--dur-2) var(--ease), border-color var(--dur-2) var(--ease);
  }
  .rub-card:hover { transform: translateY(-4px); border-color: var(--ink); }
  .rub-card__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.1rem; }
  .rub-card__icon {
    width: 50px; height: 50px; display: grid; place-items: center;
    border-radius: 14px; background: var(--accent-soft); color: var(--accent);
  }
  .rub-card__count { font-family: var(--font-mono); font-size: var(--step--2); color: var(--ink-mute); }
  .rub-card__name { font-size: var(--step-2); font-weight: 400; }
  .rub-card__blurb { margin-top: 0.5rem; color: var(--ink-mute); font-size: var(--step--1); line-height: 1.5; }
  .rub-card__list { list-style: none; padding: 1.1rem 0 0; margin: 1.1rem 0 0; border-top: 1px solid var(--line); display: grid; gap: 0.5rem; flex: 1; }
  .rub-card__list li {
    font-size: var(--step--1); color: var(--ink-soft); line-height: 1.35;
    padding-left: 1rem; position: relative;
    overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
  }
  .rub-card__list li::before { content: '·'; position: absolute; left: 0; color: var(--accent); font-weight: 700; }
  .rub-card__go {
    margin-top: 1.3rem; font-size: var(--step--1); font-weight: 540; color: var(--accent);
    display: inline-flex; align-items: center; gap: 0.4rem;
  }
  .rub-card:hover .btn__arrow { transform: translateX(4px); }
  .btn__arrow { transition: transform var(--dur-2) var(--ease); }
</style>
