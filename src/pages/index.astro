---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import { loadPosts, getCategoriesWithCounts, totalSourceCount } from '../lib/posts';
import { SITE } from '../lib/site';

const posts = loadPosts();
const cats = getCategoriesWithCounts();
const total = totalSourceCount();
const published = posts.length;

const feature = posts[0];
const secondary = posts.slice(1, 5);
const latest = posts.slice(5, 15);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE.origin}/#website`,
    name: SITE.fullName,
    url: SITE.origin + '/',
    description: SITE.description,
    inLanguage: 'fr-FR',
    publisher: { '@id': `${SITE.origin}/#org` },
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${SITE.origin}/articles/?q={query}` },
      'query-input': 'required name=query',
    },
  },
];
const words = ['décider', 'comprendre', 'choisir', 'anticiper', 'agir'];
---

<BaseLayout title={SITE.fullName} description={SITE.description} type="website" jsonLd={jsonLd}>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero__grid" aria-hidden="true"></div>
    <div class="container hero__inner">
      <div class="hero__top" data-reveal>
        <span class="u-label u-label--accent">Magazine associatif · Depuis 2023</span>
        <span class="u-label hero__count u-num">{String(total).padStart(3, '0')} sujets</span>
      </div>

      <h1 class="hero__title" data-reveal>
        <span class="hero__title-lead">L'information qui vous<br />aide à </span><span class="hero__rotator" aria-hidden="true"><span class="hero__words">{words.map((w) => <span>{w}</span>)}</span></span><span class="hero__title-end"><br />— sans le bruit.</span>
        <span class="visually-hidden">L'information qui vous aide à décider, sans le bruit.</span>
      </h1>

      <p class="hero__lead measure" data-reveal style="--reveal-delay:.05s">
        {SITE.description}
      </p>

      <div class="hero__actions" data-reveal style="--reveal-delay:.1s">
        <a href="/articles/" class="btn btn--solid">Explorer les articles <span class="btn__arrow">→</span></a>
        <a href="/rubriques/" class="btn">Parcourir les rubriques</a>
      </div>

      <dl class="hero__stats" data-reveal style="--reveal-delay:.15s">
        <div><dt>Rubriques</dt><dd class="u-num">{cats.length}</dd></div>
        <div><dt>Articles</dt><dd class="u-num">{total}</dd></div>
        <div><dt>Indépendant</dt><dd>100&nbsp;%</dd></div>
        <div><dt>Publicité</dt><dd>Zéro</dd></div>
      </dl>
    </div>
  </section>

  <!-- ============ RUBRIQUES MARQUEE ============ -->
  <section class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...cats, ...cats].map((c) => (
        <span class="marquee__item"><span class="marquee__dot"></span>{c.name}</span>
      ))}
    </div>
  </section>

  {feature && (
    <section class="container section">
      <div class="section__head">
        <span class="u-label u-label--accent">À la une</span>
        <a href="/articles/" class="link section__more">Tout voir →</a>
      </div>
      <div class="feature-grid">
        <div class="feature-grid__main">
          <PostCard post={feature} variant="feature" eager={true} />
        </div>
        <div class="feature-grid__side">
          {secondary.map((p) => <PostCard post={p} variant="card" />)}
        </div>
      </div>
    </section>
  )}

  <!-- ============ RUBRIQUES ============ -->
  {cats.length > 0 && (
    <section class="container section">
      <div class="section__head">
        <span class="u-label u-label--accent">Explorer par thème</span>
        <h2 class="section__title">Les rubriques du magazine</h2>
      </div>
      <div class="cat-grid">
        {cats.map((c, i) => (
          <a href={`/rubriques/${c.slug}/`} class="cat-card" data-reveal style={`--reveal-delay:${i * 0.03}s`}>
            <span class="cat-card__icon"><CategoryIcon name={c.icon} size={22} /></span>
            <span class="cat-card__body">
              <span class="cat-card__name">{c.name}</span>
              <span class="cat-card__blurb">{c.blurb}</span>
            </span>
            <span class="cat-card__count u-num">{c.count}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {latest.length > 0 && (
    <section class="container section">
      <div class="section__head">
        <span class="u-label u-label--accent">Derniers articles</span>
        <h2 class="section__title">Fraîchement publié</h2>
      </div>
      <div class="index-list">
        {latest.map((p, i) => <PostCard post={p} variant="row" index={i} />)}
      </div>
      <div class="section__foot">
        <a href="/articles/" class="btn">Voir tous les articles <span class="btn__arrow">→</span></a>
      </div>
    </section>
  )}

  <!-- ============ CTA ============ -->
  <section class="container">
    <div class="cta" data-reveal>
      <div class="cta__glow" aria-hidden="true"></div>
      <span class="u-label">Le projet CDA</span>
      <p class="cta__text">Un média associatif, sans publicité, qui remet la clarté au centre.</p>
      <a href="/a-propos/" class="btn btn--accent">Découvrir la démarche <span class="btn__arrow">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    padding: clamp(3rem, 8vw, 6.5rem) 0 clamp(2.5rem, 6vw, 4rem);
    overflow: hidden;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, var(--line-2) 1px, transparent 0);
    background-size: 34px 34px;
    mask-image: radial-gradient(120% 90% at 50% 0%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(120% 90% at 50% 0%, black 30%, transparent 75%);
    opacity: 0.6;
  }
  .hero__inner { position: relative; }
  .hero__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: clamp(1.6rem, 4vw, 2.6rem);
  }
  .hero__title {
    font-size: var(--step-6);
    font-weight: 340;
    line-height: 1.0;
    letter-spacing: -0.035em;
  }
  .hero__rotator {
    display: inline-flex;
    height: 1.12em;
    overflow: hidden;
    vertical-align: bottom;
    color: var(--accent);
    font-style: italic;
  }
  .hero__words {
    display: flex;
    flex-direction: column;
    animation: rotate-words 11s cubic-bezier(0.7, 0, 0.2, 1) infinite;
  }
  .hero__words span {
    display: block;
    height: 1.12em;
    line-height: 1.12;
    white-space: nowrap;
  }
  @keyframes rotate-words {
    0%, 17% { transform: translateY(0); }
    20%, 37% { transform: translateY(-1.12em); }
    40%, 57% { transform: translateY(-2.24em); }
    60%, 77% { transform: translateY(-3.36em); }
    80%, 97% { transform: translateY(-4.48em); }
    100% { transform: translateY(-4.48em); }
  }
  .hero__title-end { color: var(--ink); }
  @media (prefers-reduced-motion: reduce) {
    .hero__words { animation: none; }
  }
  .hero__lead {
    margin-top: 1.8rem;
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--ink-soft);
    font-weight: 400;
  }
  .hero__actions { margin-top: 2rem; display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .hero__stats {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    overflow: hidden;
  }
  .hero__stats > div { background: var(--paper); padding: 1.3rem 1.4rem; }
  .hero__stats dt { font-size: var(--step--2); color: var(--ink-mute); letter-spacing: 0.08em; text-transform: uppercase; }
  .hero__stats dd {
    margin: 0.3rem 0 0;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    letter-spacing: -0.03em;
  }
  @media (max-width: 640px) {
    .hero__stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* ---------- MARQUEE ---------- */
  .marquee {
    border-block: 1px solid var(--line);
    padding: 0.9rem 0;
    overflow: hidden;
    white-space: nowrap;
    margin-top: 1rem;
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }
  .marquee__track { display: inline-flex; gap: 3rem; animation: marquee 42s linear infinite; }
  .marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--ink-mute);
    font-weight: 360;
  }
  .marquee__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }

  /* ---------- SECTIONS ---------- */
  .section { margin-top: clamp(3.5rem, 8vw, 6rem); }
  .section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .section__title { font-size: var(--step-4); margin-top: 0.35rem; flex-basis: 100%; }
  .section__more { font-size: var(--step--1); color: var(--ink-mute); }
  .section__foot { margin-top: 2.5rem; text-align: center; }

  .feature-grid { display: grid; grid-template-columns: 1.35fr 1fr; gap: 2rem; }
  .feature-grid__side { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-content: start; }
  @media (max-width: 900px) {
    .feature-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 520px) {
    .feature-grid__side { grid-template-columns: 1fr; }
  }

  /* ---------- CATÉGORIES ---------- */
  .cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  @media (max-width: 820px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .cat-grid { grid-template-columns: 1fr; } }
  .cat-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.3rem;
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    background: var(--surface);
    transition: transform var(--dur-2) var(--ease), border-color var(--dur-2) var(--ease);
  }
  .cat-card:hover { transform: translateY(-3px); border-color: var(--ink); }
  .cat-card__icon {
    flex: none;
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--accent);
  }
  .cat-card__body { display: flex; flex-direction: column; gap: 0.25rem; min-width: 0; flex: 1; }
  .cat-card__name { font-weight: 600; letter-spacing: -0.01em; }
  .cat-card__blurb { font-size: var(--step--1); color: var(--ink-mute); line-height: 1.45; }
  .cat-card__count { font-family: var(--font-mono); font-size: var(--step--1); color: var(--ink-mute); }

  /* ---------- CTA ---------- */
  .cta {
    position: relative;
    margin-top: var(--sp-9);
    padding: clamp(2.5rem, 6vw, 4.5rem) var(--gutter);
    text-align: center;
    border: 1px solid var(--line);
    border-radius: var(--r-3);
    background: var(--surface);
    overflow: hidden;
  }
  .cta__glow {
    position: absolute;
    top: -40%;
    left: 50%;
    width: 60%;
    height: 100%;
    transform: translateX(-50%);
    background: radial-gradient(circle, var(--accent-soft), transparent 65%);
    opacity: 0.9;
  }
  .cta__text {
    position: relative;
    margin: 0.8rem auto 1.8rem;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 360;
    letter-spacing: -0.025em;
    max-width: 20ch;
    line-height: 1.1;
  }
</style>
