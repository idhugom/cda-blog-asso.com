---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/prose.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
  bodyClass?: string;
  showProgress?: boolean;
}

const {
  title,
  description,
  canonical,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  section,
  tags = [],
  jsonLd = [],
  noindex = false,
  bodyClass = '',
  showProgress = false,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, SITE.origin).href;
const ogImage = image || new URL('/og-default.png', SITE.origin).href;
const fullTitle =
  title === SITE.fullName ? title : `${title} — ${SITE.name}`;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.origin}/#org`,
  name: SITE.publisher,
  url: SITE.origin + '/',
  description: SITE.description,
};
const allLd = [orgLd, ...jsonLd];
---

<!doctype html>
<html lang={SITE.lang} data-theme-default>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large" />}

    <meta name="theme-color" content="#faf9f6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b0b0d" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {section && <meta property="article:section" content={section} />}
    {tags.map((t) => <meta property="article:tag" content={t} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="format-detection" content="telephone=no" />

    {allLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />)}

    <!-- Anti-FOUC : applique le thème avant le premier paint -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('cda-theme');
          if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip">Aller au contenu</a>
    {showProgress && <div class="progress" id="progress" aria-hidden="true"></div>}
    <noscript><p class="noscript-note">Ce site fonctionne sans JavaScript — les animations sont simplement désactivées.</p></noscript>

    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // — Interactions globales (léger, sans dépendance) —
      const mq = window.matchMedia('(prefers-reduced-motion: reduce)');

      // Reveals au scroll
      function initReveals() {
        const els = document.querySelectorAll('[data-reveal], [data-reveal-line]');
        if (mq.matches || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.setAttribute(el.hasAttribute('data-reveal') ? 'data-reveal' : 'data-reveal-line', 'in'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                const el = e.target as HTMLElement;
                el.setAttribute(el.hasAttribute('data-reveal') ? 'data-reveal' : 'data-reveal-line', 'in');
                io.unobserve(el);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      }

      // Barre de progression de lecture
      function initProgress() {
        const bar = document.getElementById('progress');
        if (!bar) return;
        let ticking = false;
        const update = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          const p = max > 0 ? Math.min(1, h.scrollTop / max) : 0;
          bar.style.setProperty('--p', String(p));
          ticking = false;
        };
        document.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
          }
        }, { passive: true });
        update();
      }

      // Bascule de thème
      function initTheme() {
        const root = document.documentElement;
        document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const current =
              root.getAttribute('data-theme') ||
              (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            const next = current === 'dark' ? 'light' : 'dark';
            root.setAttribute('data-theme', next);
            try { localStorage.setItem('cda-theme', next); } catch (e) {}
          });
        });
      }

      // Menu mobile
      function initMenu() {
        const btn = document.querySelector('[data-menu-toggle]');
        const nav = document.getElementById('site-nav');
        if (!btn || !nav) return;
        btn.addEventListener('click', () => {
          const open = nav.getAttribute('data-open') === 'true';
          nav.setAttribute('data-open', String(!open));
          btn.setAttribute('aria-expanded', String(!open));
          document.body.style.overflow = !open ? 'hidden' : '';
        });
        nav.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => {
            nav.setAttribute('data-open', 'false');
            btn.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
          })
        );
      }

      // Header : ombre/condensation au scroll
      function initHeader() {
        const header = document.querySelector('[data-header]');
        if (!header) return;
        let last = 0;
        document.addEventListener('scroll', () => {
          const y = window.scrollY;
          header.setAttribute('data-scrolled', String(y > 12));
          last = y;
        }, { passive: true });
      }

      function boot() {
        initReveals();
        initProgress();
        initTheme();
        initMenu();
        initHeader();
      }
      boot();
      document.addEventListener('astro:page-load', boot);
    </script>
  </body>
</html>
